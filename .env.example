# ── Telegram Userbot ─────────────────────────────────────────────────────────
# Get from https://my.telegram.org → API development tools
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+46701234567         # Your phone number in international format

# Username of the Smith™ Gold VIP channel (without @)
SIGNAL_CHANNEL=SmithGoldVIP

# Your Telegram user ID (where trade notifications are sent)
NOTIFY_CHAT_ID=693111427

# ── Account / Risk ────────────────────────────────────────────────────────────
# Simulated account size in USD (£1000 ≈ $1270)
# Smith's rule: 0.01 lots per TP per £500 → £1000 = 0.02 lots per trade × 4 = 0.08 lots total
ACCOUNT_SIZE_USD=1270

# ── Broker ────────────────────────────────────────────────────────────────────
# "paper" for simulation, "binance" or "bitget" for live trading
BROKER=paper

# Binance Futures (when BROKER=binance)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Bitget Futures (when BROKER=bitget)
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
